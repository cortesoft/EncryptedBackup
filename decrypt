#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

if [ ! -f "encrypted" ]; then
    echo "Error: 'encrypted' file not found."
    exit 1
fi

if [ -d "unencrypted" ]; then
    echo "Error: 'unencrypted' directory already exists. Remove it first."
    exit 1
fi

# Prompt for password
read -r -s -p "Enter decryption password: " PASSWORD
echo

if [ -z "$PASSWORD" ]; then
    echo "Error: Password cannot be empty."
    exit 1
fi

echo "Decrypting..."

# Decrypt and extract
# Password passed via environment variable to avoid exposure in process listing
export ENCRYPTION_PASSWORD="$PASSWORD"
unset PASSWORD

openssl enc -d -aes-256-cbc -pbkdf2 -iter 600000 -salt \
    -pass env:ENCRYPTION_PASSWORD -in encrypted | \
    tar -xzf - -C .

unset ENCRYPTION_PASSWORD

echo "Done. Files are in 'unencrypted' directory."
